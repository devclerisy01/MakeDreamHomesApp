{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"src/main.tsx",
		"vite.config.ts",
		"cypress.config.ts",
		"cypress/support/e2e.ts",
		"cypress/e2e/**/*.cy.ts"
	],
	"project": ["src/**/*.{ts,tsx}", "cypress/**/*.ts"],
	"ignoreExportsUsedInFile": true,
	"ignoreDependencies": [
		"@types/.*",
		"@capacitor/core",
		"@capacitor/app",
		"@capacitor/haptics",
		"@capacitor/keyboard",
		"@capacitor/status-bar",
		"ionicons",
		"eslint-plugin-react",
		"@testing-library/user-event",
		"terser"
	]
}
